# ─────────────────────────────────────────────────────────────────────────────
# Friday Agent — Environment Variables
# Copy this file to .env and fill in the values you need.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Choose one: gemini | openai | copilot | ollama
LLM_PROVIDER=gemini

# Optional: override the default model for your chosen provider
# LLM_MODEL=gemini-2.5-flash

# ── Google Gemini ─────────────────────────────────────────────────────────────
# Get from https://aistudio.google.com/projects
GOOGLE_API_KEY=your-google-api-key

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxx

# ── GitHub Copilot LLM (GitHub Models API) ───────────────────────────────────
# Uses your existing GitHub token — no extra cost beyond your Copilot subscription.
# Create a fine-grained token at https://github.com/settings/tokens
GH_TOKEN=ghp_xxxxxxxxxxxxxxxx
# COPILOT_MODEL=gpt-4o

# ── Ollama (self-hosted, no API key required) ─────────────────────────────────
# Run Ollama locally: https://ollama.com
# Or point at a remote instance (e.g. http://192.168.1.10:11434)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Create a bot with @BotFather on Telegram (free, no paid plan needed)
TELEGRAM_TOKEN=your-telegram-bot-token

# ── Server identity (optional) ───────────────────────────────────────────────
SERVER_NAME=Friday
DEBUG=false

# ─────────────────────────────────────────────────────────────────────────────
# Local voice agent (voice_local.py / uv run friday_voice_local)
# Uses faster-whisper for on-device STT — no STT API key required.
# Install deps: uv sync --extra voice-local
# ─────────────────────────────────────────────────────────────────────────────

# Whisper model size: tiny | base | small | medium | large-v3  (default: base)
# WHISPER_MODEL=base
# Compute device: cpu | cuda  (default: cpu)
# WHISPER_DEVICE=cpu

# ─────────────────────────────────────────────────────────────────────────────
# Voice agent (agent_friday.py / uv run friday_voice)
# Requires LiveKit for the room transport.
# Only needed if you use the standalone LiveKit voice agent.
# ─────────────────────────────────────────────────────────────────────────────

# LIVEKIT_URL=wss://your-project-xxxxx.livekit.cloud
# LIVEKIT_API_KEY=APIxxxxxxxxxxxxx
# LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
