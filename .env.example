# ─────────────────────────────────────────────────────────────────────────────
# Friday Agent — Environment Variables
# Copy this file to .env and fill in the values you need.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Choose one: gemini | openai | copilot | ollama
LLM_PROVIDER=gemini

# Optional: override the default model for your chosen provider
# LLM_MODEL=gemini-2.5-flash

# ── Google Gemini ─────────────────────────────────────────────────────────────
# Get from https://aistudio.google.com/projects
GOOGLE_API_KEY=your-google-api-key

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Get from https://platform.openai.com/api-keys
# Also required for voice transcription (Whisper API) even when using a different LLM.
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxx

# ── GitHub Copilot LLM (GitHub Models API) ───────────────────────────────────
# Uses your existing GitHub token — no extra cost beyond your Copilot subscription.
# Create a fine-grained token at https://github.com/settings/tokens
GH_TOKEN=ghp_xxxxxxxxxxxxxxxx
# COPILOT_MODEL=gpt-4o

# ── Ollama (self-hosted, no API key required) ─────────────────────────────────
# Run Ollama locally: https://ollama.com
# Or point at a remote instance (e.g. http://192.168.1.10:11434)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Create a bot with @BotFather on Telegram (free, no paid plan needed)
TELEGRAM_TOKEN=your-telegram-bot-token

# ── Home Assistant ────────────────────────────────────────────────────────────
# HA_URL: your Home Assistant base URL (LAN IP or hostname)
# HA_TOKEN: long-lived access token — HA UI → Profile → Security → Create Token
HA_URL=http://homeassistant.local:8123
HA_TOKEN=

# ── Server identity (optional) ───────────────────────────────────────────────
SERVER_NAME=Friday
DEBUG=false

# ── MCP Server ────────────────────────────────────────────────────────────────
FRIDAY_MCP_TRANSPORT=sse
FRIDAY_MCP_WORKSPACE_ROOT=.
FRIDAY_MCP_SKILLS_ROOT=./skills
FRIDAY_MCP_ALLOW_EXTERNAL_PATHS=false
FRIDAY_MCP_DEFAULT_COMMAND_TIMEOUT=30
FRIDAY_MCP_MAX_FETCH_CHARS=8000

# ── Auto-browser (LvcidPsyche/auto-browser) ───────────────────────────────────
# Run: docker compose -f docker-compose.auto-browser.yml up -d
# Then set AUTO_BROWSER_URL to enable the auto-browser tools.
AUTO_BROWSER_URL=http://127.0.0.1:8000
# AUTO_BROWSER_TOKEN=       # set if API_BEARER_TOKEN is configured in auto-browser

# ─────────────────────────────────────────────────────────────────────────────
# Desktop voice agent (voice_agent.py / uv run friday_voice)
# Local STT via faster-whisper + local TTS via Coqui — no LiveKit, no cloud keys.
# Install deps:  uv sync --extra voice
# ─────────────────────────────────────────────────────────────────────────────

# STT — faster-whisper
# WHISPER_MODEL=base.en          # tiny.en | base.en | small.en | medium.en
# WHISPER_DEVICE=cpu             # cpu | cuda

# TTS — Coqui
# TTS_MODEL=tts_models/en/ljspeech/tacotron2-DDC
#   Better options:
#     tts_models/en/jenny/jenny                               (very natural)
#     tts_models/multilingual/multi-dataset/xtts_v2           (best quality, set TTS_SPEAKER)
# TTS_SPEAKER=                   # blank for single-speaker; XTTS-v2: "Ana Florence"
# TTS_LANGUAGE=en                # for multilingual models only

# VAD (voice activity detection)
# VAD_THRESHOLD=0.015            # RMS threshold (lower = pick up quieter speech)
# SILENCE_SECS=1.5               # seconds of silence that ends an utterance
# MIN_SPEECH_SECS=0.4            # minimum speech length before transcribing
